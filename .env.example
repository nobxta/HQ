# Copy to .env and fill in your values
API_ID=
API_HASH=
ADMIN_BOT_TOKEN=
ADMIN_USER_ID=
# Optional: contact shown when subscription expired (e.g. youradmin → "Contact @youradmin")
# ADMIN_CONTACT=

# Shop Bot: Support button opens direct chat. Prefer SUPPORT_CHAT_ID (numeric Telegram user ID).
# SUPPORT_CHAT_ID=
# SUPPORT_USER_ID=  # fallback if SUPPORT_CHAT_ID not set
# WEBSITE_URL=      # optional; "Website" button URL (e.g. https://example.com)

# Shop Bot payments (required if SHOP_BOT_TOKEN is set; use PAYMENT_DEV_MODE=1 for stub only)
# NOWPAYMENTS_API_KEY=
# NOWPAYMENTS_BASE_URL=https://api.nowpayments.io/v1
# PAYMENT_DEV_MODE=1

# Optional: SOCKS proxy for NAT/censorship (requires PySocks + socksio).
# Applies to Telethon and to python-telegram-bot (admins/shop/logs) via socks5h (DNS via proxy).
# PROXY_HOST=
# PROXY_PORT=1080
# PROXY_TYPE=socks5

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Web API Configuration (for FastAPI dashboard)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# JWT secret (generate: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=
# Web admin credentials
WEB_ADMIN_USER=admin
# Generate hash: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
WEB_ADMIN_PASS_HASH=
# API server config
API_PORT=8000
API_HOST=0.0.0.0
# CORS origins (comma-separated, or * for all)
CORS_ORIGINS=*

# Cloudflare Tunnel (tunnel.py) — auto-started on Linux hosts to expose the API as api.hqadz.io.
# TUNNEL_DISABLE=1        # skip the tunnel entirely
# TUNNEL_FORCE=1          # force it on non-Linux hosts (local dev)
# TUNNEL_PROTOCOL=http2   # http2 (default, TCP-based) | quic | auto — quic/auto need reliable UDP,
#                         # which many Docker/Pterodactyl hosts block or drop, causing endless
#                         # "failed to accept QUIC stream" / "no recent network activity" reconnect loops
# TUNNEL_METRICS_PORT=20241  # local port cloudflared exposes /ready on; used by the watchdog
