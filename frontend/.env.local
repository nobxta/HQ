# Backend API URL (FastAPI server)
NEXT_PUBLIC_API_URL=https://api.hqadz.io

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-random-secret-string-min-32-chars

# Admin credentials (must match WEB_ADMIN_USER / WEB_ADMIN_PASS_HASH in backend .env)
# These are only used by NextAuth to proxy login to the backend API
